{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",

        "strict": true,

        "allowJs": true,
        "checkJs": false,

        "resolveJsonModule": true,
        "esModuleInterop": true,
        "isolatedModules": true,

        "skipLibCheck": true,
        "noEmit": true,

        "sourceMap": true,

        "lib": ["DOM", "DOM.Iterable", "ES2022"]
    },

    "include": ["resources/**/*", "vite.config.js"],

    "exclude": ["node_modules", "vendor"]
}
